<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />
    <!-- The rolling file appender is a dev convenience (logging.file.name is set only in the dev profile);
         prod and the tests log to the console only, captured by the platform / build. -->
    <springProfile name="dev">
        <include resource="org/springframework/boot/logging/logback/file-appender.xml" />
    </springProfile>

    <!-- springProfile must wrap a whole <root>, not sit inside it, so each profile gets its own root: dev
         adds the FILE appender (defined only in the dev include above); every other profile logs to the
         console only. -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
    </springProfile>
    <springProfile name="!dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>
</configuration>
