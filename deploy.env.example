# Copy to deploy.prod.env (gitignored) and fill in before deploying to Cloud Run. deploy.prod.env is the
# local source of truth for both the deployment secrets and the non-secret config. scripts/deploy-cloudrun.sh
# reads it, SYNCS the four secrets into Google Secret Manager (creating each, or adding a new version when the
# value changes), and deploys: the secrets are bound onto the service from Secret Manager with --set-secrets,
# the non-secret config with --set-env-vars. So the editable copy stays on your machine and the runtime reads
# the secrets from Secret Manager. See doc/2026-06-25_secret-manager-for-deployment-secrets.md and the README.

# === Secrets (synced from here into Secret Manager by the deploy) ===

# HMAC signing secret for admin JWTs. Required, at least 32 bytes. Secret Manager secret: jwt-secret.
# Generate: printf 'JWT_SECRET=%s\n' "$(openssl rand -hex 32)" >> deploy.prod.env
JWT_SECRET=REPLACE_ME

# RSA private key (PKCS#8 PEM) that decrypts the login payload; the SPA encrypts with the matching public key.
# Required, at least 2048 bits. May be a normal multi-line PEM (the app also turns literal `\n` into newlines).
# Secret Manager secret: login-key.
# Generate (multi-line is fine here): { printf 'LOGIN_PRIVATE_KEY_PEM='; openssl genpkey -algorithm RSA \
#   -pkeyopt rsa_keygen_bits:2048; } >> deploy.prod.env
LOGIN_PRIVATE_KEY_PEM=REPLACE_ME

# Password for DB_USERNAME (the prod profile connects via the Cloud SQL socket factory). Required.
# Secret Manager secret: db-app-password.
DB_PASSWORD=REPLACE_ME

# First-admin password, used once on a fresh database to create the initial admin (no fixtures in prod).
# Required. Secret Manager secret: bootstrap-admin-password.
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_ME

# === Non-secret config (passed to the service with --set-env-vars) ===

# Cloud SQL instance connection name (project:region:instance) the prod profile connects to via the socket
# factory. Required in prod. Find it with:
#   gcloud sql instances describe <instance> --format='value(connectionName)'
CLOUD_SQL_INSTANCE=your-project:your-region:your-instance

# Database role the app runs as. The master `postgres` works; a dedicated least-privilege role is preferable
# where you can provision one (scripts/sql/create-app-role.sql). DB_PASSWORD above is this role's password.
DB_USERNAME=postgres

# Public https origin the app is reached at (the Cloud Run service URL or a custom domain). The capability
# QR/login URLs are built from it, so it must be the real https URL. Prod refuses to start without it. Start it
# as https://pending.invalid; scripts/deploy-cloudrun.sh writes the resolved Cloud Run URL back here after the
# first deploy.
CAMPUS_COFFEE_APP_BASE_URL=https://pending.invalid

# First-admin identity (the password is BOOTSTRAP_ADMIN_PASSWORD above). FIRST_NAME / LAST_NAME are optional.
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_EMAIL=admin@se.uni-heidelberg.de
BOOTSTRAP_ADMIN_FIRST_NAME=Bootstrap
BOOTSTRAP_ADMIN_LAST_NAME=Admin
