# Copy to deploy.env (gitignored) and fill in before deploying to Cloud Run. compose.prod.yaml loads this
# via `env_file`, so `gcloud run compose up` sets these on the service. scripts/deploy-cloudrun.sh fills in
# the random secrets and the resolved service URL for you on first run; this file documents what is needed.
#
# Generate a JWT secret portably (works on macOS and Linux):
#   printf 'JWT_SECRET=%s\n' "$(openssl rand -hex 32)" >> deploy.env

# HMAC signing secret for admin JWTs. Required, at least 32 bytes.
JWT_SECRET=REPLACE_ME

# Managed Cloud SQL database password (the prod profile reads campus-coffee via the socket factory; supply
# the password here or, better, from Secret Manager). Required.
DB_PASSWORD=REPLACE_ME

# Public https origin the app is reached at (the Cloud Run service URL or a custom domain). The capability
# QR/login URLs are built from it, so it must be the real https URL. Prod refuses to start without it.
CAMPUS_COFFEE_APP_BASE_URL=https://REPLACE_ME.run.app

# First-admin credentials, used once on a fresh database to create the initial admin (no fixtures in prod).
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_ME
BOOTSTRAP_ADMIN_EMAIL=admin@se.uni-heidelberg.de
