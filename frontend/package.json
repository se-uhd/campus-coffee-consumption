{
  "name": "campus-coffee-consumption-frontend",
  "version": "0.1.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:coverage": "ng build --configuration coverage",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch",
    "test:coverage": "ng test --no-watch --configuration coverage",
    "e2e": "playwright test",
    "e2e:coverage": "PW_COVERAGE=1 playwright test",
    "lint": "ng lint && npm run lint:css",
    "lint:css": "stylelint \"src/**/*.scss\" --ignore-path .stylelintignore",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json,md}\"",
    "knip": "knip"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "material-icons": "^1.13.14",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "2.39.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "istanbul-lib-instrument": "^6.0.3",
    "jsdom": "^28.0.0",
    "knip": "^6.17.1",
    "monocart-coverage-reports": "^2.12.12",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
